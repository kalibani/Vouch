# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Anthropic (Claude) ---
# Haiku 4.5 handles extraction/translation; Sonnet 4.6 handles reasoning/generation.
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (dedicated project for this service; never reuse a prod project) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# --- GitHub (LOCAL push only) ---
# Set GITHUB_TOKEN in your local .env (gitignored) for pushing. Never commit it,
# and never paste it into an AI conversation you intend to export.
# GITHUB_TOKEN=...
